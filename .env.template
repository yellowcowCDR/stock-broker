# ==========================================
# Hermes Trading Broker - Environment Variables
# ==========================================
# 사용법: 
# 1. 이 파일을 복사하여 `.env` 라는 이름의 파일로 만듭니다. ($ cp .env.template .env)
# 2. 실제 운영/모의투자 환경에 맞는 값으로 아래 내용을 채워넣습니다.
# 3. 도커 실행 시 `--env-file .env` 옵션을 추가하여 실행합니다.

# ------------------------------------------
# [1] Spring Boot 실행 모드 설정
# ------------------------------------------
# 'mock' (모의투자) 또는 'prod' (실전투자) 중 선택하여 입력하세요.
SPRING_PROFILES_ACTIVE=mock
TZ=UTC

# 기본값은 분석 전용입니다. PAPER_AUTO/LIVE_AUTO 전환 전에 Broker Risk 데이터 완전성을 확인하세요.
AUTONOMY_MODE=ANALYSIS_ONLY
REAL_ORDER_ENABLED=false
LIVE_TRADING_ENABLED=false
ENTRY_KILL_SWITCH_ENABLED=true
OVERSEAS_ORDER_ENABLED=false
# 미국 Paper 주문을 켤 때만 사용합니다. 실전 해외 주문은 코드에서 계속 차단됩니다.
OVERSEAS_MAX_ORDER_AMOUNT_USD=1000
OVERSEAS_MAX_DAILY_TRADES=5
OVERSEAS_MAX_POSITION_COUNT=5
OVERSEAS_MAX_STOCK_EXPOSURE_RATE=0.25
OVERSEAS_ALLOW_AVERAGING_DOWN=false
# Reset endpoint is absent unless a paper operator enables it temporarily.
ADMIN_RESET_ENABLED=false

# Operational metrics/health thresholds
BROKER_MONITORING_ENABLED=true
MONITOR_CONTEXT_WARNING_BEFORE=1m
MONITOR_NEWS_MAX_AGE=24h
MONITOR_WATCHLIST_MAX_AGE=15m
MONITOR_OVERVIEW_MAX_AGE=10m
MONITOR_EXTERNAL_FAILURE_WINDOW=15m
MONITOR_RECONCILIATION_FAILURE_WINDOW=30m
MONITOR_DATABASE_FAILURE_WINDOW=15m
MONITOR_CRON_GRACE=5m

# Risk 데이터가 완성되지 않았을 때 신규 매수를 fail-closed로 차단합니다.
RISK_POLICY_VERSION=v1
REQUIRE_SECTOR_DATA=true
REQUIRE_DAILY_LOSS_DATA=true

# 시장 overview와 Hermes 분석 context는 짧게 갱신합니다. UTC ISO-8601 validUntil을 사용합니다.
MARKET_OVERVIEW_FRESHNESS=5m
MARKET_CONTEXT_MAX_VALIDITY=5m
MARKET_CONTEXT_HISTORY_LIMIT=100

# ------------------------------------------
# [2] Database (PostgreSQL - Neon Serverless)
# ------------------------------------------
# DB 접속 정보 (모의투자와 실전투자가 같은 DB를 쓴다면 공통으로 사용)
DB_URL=jdbc:postgresql://<neon-db-url>:5432/<database-name>
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# ------------------------------------------
# [3] KIS 한국투자증권 API - 모의투자 (Mock)
# ------------------------------------------
# SPRING_PROFILES_ACTIVE=mock 일 때 읽혀집니다.
KIS_MOCK_APP_KEY=your_mock_app_key_here
KIS_MOCK_APP_SECRET=your_mock_app_secret_here
KIS_MOCK_ACCOUNT_NO=12345678-01

# ------------------------------------------
# [4] KIS 한국투자증권 API - 실전투자 (Prod)
# ------------------------------------------
# SPRING_PROFILES_ACTIVE=prod 일 때 읽혀집니다.
KIS_PROD_APP_KEY=your_prod_app_key_here
KIS_PROD_APP_SECRET=your_prod_app_secret_here
KIS_PROD_ACCOUNT_NO=12345678-01

# ------------------------------------------
# [5] 실데이터 공급자
# ------------------------------------------
# 값이 없거나 API 호출에 실패하면 Mock으로 대체하지 않고 요청을 실패시킵니다.
NAVER_NEWS_ENABLED=true
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here
NAVER_NEWS_FRESHNESS_THRESHOLD=24h

# Watchlist는 KIS 국내 거래대금 순위와 미국 거래대금 순위에서 생성되는 분석 후보군입니다.
WATCHLIST_DOMESTIC_LIMIT=10
WATCHLIST_OVERSEAS_PER_EXCHANGE_LIMIT=5
WATCHLIST_MAX_CANDIDATES=25
WATCHLIST_MIN_DOMESTIC_VOLUME=100000

OPENDART_ENABLED=true
OPENDART_API_KEY=your_opendart_api_key_here

# 미국 재무제표·실적 이력·실적 캘린더. 키가 없으면 미국 재무 API는 fail-closed로 실패합니다.
# REQUIRE_SECTOR_DATA=true인 미국 신규 매수에는 OVERVIEW의 Sector가 필요합니다.
ALPHA_VANTAGE_ENABLED=false
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here
ALPHA_VANTAGE_EARNINGS_HORIZON=3month
